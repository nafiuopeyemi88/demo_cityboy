# ── ArcGIS Credentials ────────────────────────────────────────────────────────
# Get these from: https://developers.arcgis.com → Applications → New App
ARCGIS_CLIENT_ID=your_client_id_here
ARCGIS_CLIENT_SECRET=your_client_secret_here

# URL of your hosted Feature Layer (Layer 0 = current positions)
# Format: https://services.arcgis.com/<ORG_ID>/arcgis/rest/services/<SERVICE_NAME>/FeatureServer/0
ARCGIS_FEATURE_LAYER_URL=https://services.arcgis.com/YOUR_ORG_ID/arcgis/rest/services/WorkerTracker/FeatureServer/0
#https://services3.arcgis.com/2jeX0lHHEUGyYxR1/arcgis/rest/services/polling_agents/FeatureServer/0
# Optional: second layer for full location history (trail/track view)
# ARCGIS_HISTORY_LAYER_URL=https://services.arcgis.com/YOUR_ORG_ID/arcgis/rest/services/WorkerHistory/FeatureServer/0

# ── App Config ─────────────────────────────────────────────────────────────────
APP_PORT=8000
